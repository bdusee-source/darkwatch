# ─── DARKWATCH Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env.local for local development.
# NEVER commit .env.local to version control.
#
# In production, set these in the Vercel dashboard:
# Project → Settings → Environment Variables
#
# ─── CORS ─────────────────────────────────────────────────────────────────────

# Restrict API proxies to your front-end origin in production
# e.g. https://darkwatch.yourdomain.com
# Leave as * for development / testing only
ALLOWED_ORIGIN=*

# ─── Free feeds ───────────────────────────────────────────────────────────────

# Have I Been Pwned — https://haveibeenpwned.com/API/Key
# Free tier available; ~$3.50/month for unlimited queries
HIBP_API_KEY=

# AlienVault OTX — https://otx.alienvault.com (free)
OTX_API_KEY=

# PhishTank — https://www.phishtank.com/api_info.php
# Leave blank to use anonymously (lower rate limits)
PHISHTANK_API_KEY=

# URLhaus — no API key required, leave blank
# URLHAUS_API_KEY=

# ─── Paid feeds ───────────────────────────────────────────────────────────────

# Flare — https://flare.io
FLARE_API_KEY=
FLARE_TENANT_ID=

# DarkOwl — https://www.darkowl.com
DARKOWL_API_KEY=
DARKOWL_API_SECRET=

# Cybersixgill — https://www.cybersixgill.com
CYBERSIXGILL_CLIENT_ID=
CYBERSIXGILL_CLIENT_SECRET=
